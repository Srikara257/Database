    {
      "id": "iameWrdZGhmDhMPZLau7C",
      "type": "text",
      "x": 135.53672766713436,
      "y": 1341.4353585450172,
      "width": 702.7796020507812,
      "height": 550,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
